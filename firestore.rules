rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email == "mathelaureate@gmail.com";
    }

    match /userPayments/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // App-level config docs.
    match /appData/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Course content shown to students.
    match /courseContentItems/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Per-user progress and profile-style state.
    match /userCourseProgress/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Default deny for all other documents.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
